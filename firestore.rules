rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasAdminToken() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == "admin"
      );
    }

    function hasAdminProfile() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true
        );
    }

    function isAdmin() {
      return hasAdminToken() || hasAdminProfile();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /transferRequests/{requestId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "awaiting_payment";
      allow update: if isAdmin() || (
        signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookId == resource.data.bookId
        && request.resource.data.bookTitle == resource.data.bookTitle
        && request.resource.data.userEmail == resource.data.userEmail
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.currency == resource.data.currency
        && request.resource.data.paymentReference == resource.data.paymentReference
        && request.resource.data.bankName == resource.data.bankName
        && request.resource.data.accountName == resource.data.accountName
        && request.resource.data.accountNumber == resource.data.accountNumber
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.reviewedAt == resource.data.reviewedAt
        && request.resource.data.reviewedBy == resource.data.reviewedBy
        && request.resource.data.adminNote == resource.data.adminNote
        && resource.data.status == "awaiting_payment"
        && request.resource.data.status == "payment_submitted"
      );
      allow delete: if isAdmin();
    }
  }
}
